# Normalize all text files to LF
* text=auto eol=lf

# Explicit text types
*.html text
*.css text
*.js text
*.json text
*.md text
*.txt text
*.xml text
*.yml text
*.yaml text

# Prevent corruption of binary assets
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.svg binary

# Fonts
*.woff binary
*.woff2 binary
*.ttf binary
*.otf binary

# Archives
*.zip binary
*.gz binary
*.tar binary

# Media
*.mp3 binary
*.wav binary
*.mp4 binary
*.mov binary
